# Copy to .env.local and fill in values. Never commit .env.local.

# Required for /api/generate-reply when clients do not send a key
OPENAI_API_KEY=

# Optional
# OPENAI_MODEL=gpt-5.4
# NEXT_PUBLIC_SITE_URL=https://smartreply.space

# Support form (POST /api/support) — get a key at https://resend.com
RESEND_API_KEY=
# Verified sender. For testing, Resend allows onboarding@resend.dev; for production use your domain in Resend.
# RESEND_FROM=SmartReply <support@smartreply.space>
