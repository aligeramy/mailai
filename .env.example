# Copy to .env.local and fill in values. Never commit .env.local.

# Required for /api/generate-reply when clients do not send a key
OPENAI_API_KEY=

# Optional
# OPENAI_MODEL=gpt-5.4
# NEXT_PUBLIC_SITE_URL=https://smartreply.space

# Support form (POST /api/support) — get a key at https://resend.com
RESEND_API_KEY=
# Verified sender. For testing, Resend allows onboarding@resend.dev; for production use your domain in Resend.
# RESEND_FROM=SmartReply <support@smartreply.space>

# Microsoft Graph mailbox history (Outlook add-in).
# Application (client) ID from your Entra ID app registration.
# Setup:
#   1. portal.azure.com → Microsoft Entra ID → App registrations → New registration
#      - Account types: "Accounts in any organizational directory and personal Microsoft accounts"
#      - Redirect URI: Single-page application (SPA) → https://smartreply.space/taskpane
#        (add https://localhost:3000/taskpane for dev)
#   2. API permissions → Add → Microsoft Graph → Delegated → Mail.Read → Grant admin consent.
#   3. Authentication → Allow public client flows: Yes. Enable "Live SDK support".
#   4. Manifest → set "signInAudience" to "AzureADandPersonalMicrosoftAccount" and add the
#      add-in URI to "trustedClientApplications" if you publish a paired Office add-in manifest.
# Copy the Application (client) ID below. NEXT_PUBLIC_ exposes it to the browser; that's required
# for MSAL.js in the taskpane and is safe — public clients have no secret.
NEXT_PUBLIC_AZURE_CLIENT_ID=

# Tenant ID for the Entra app above. Required if the app's signInAudience is single-tenant
# (AzureADMyOrg). Leave blank for multi-tenant apps to use the /common authority.
NEXT_PUBLIC_AZURE_TENANT_ID=
