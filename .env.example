# Public site URL (no trailing slash) — used for SEO, sitemap, Open Graph
NEXT_PUBLIC_SITE_URL=https://smartreply.space

# Outlook add-in CTA (AppSource listing, OWA, or sideload docs)
NEXT_PUBLIC_OUTLOOK_ADDIN_URL=https://outlook.office.com/mail/inbox

# Server-side OpenAI (required for /api/generate-reply when users do not pass a client key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
# OPENAI_BASE_URL=
# OPENAI_REASONING_EFFORT=medium
