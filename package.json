{
  "name": "mailai-smart-email-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "MailAI - Smart Email Assistant. AI-powered email reply generation for Outlook and Gmail.",
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:https": "next dev --port 3000 --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "doctor": "npx -y react-doctor@latest . --verbose --diff",
    "validate:manifest": "npx -y office-addin-manifest@latest validate public/manifest.xml",
    "generate:store-icons": "python3 scripts/generate-partner-center-icons.py",
    "package:addin": "pnpm generate:store-icons && pnpm validate:manifest && rm -f dist/smartreply-outlook-addin.zip && rm -rf dist/package-staging && mkdir -p dist/package-staging/assets && cp public/manifest.json dist/package-staging/manifest.json && cp public/assets/icon-color-192.png public/assets/icon-outline-32.png dist/package-staging/assets/ && (cd dist/package-staging && zip -r ../smartreply-outlook-addin.zip manifest.json assets) && rm -rf dist/package-staging"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.11.0",
    "@base-ui/react": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@react-email/tailwind": "^2.0.6",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "next": "16.2.1",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "openai": "^4.82.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.4",
    "shadcn": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/office-js": "^1.0.430",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "office-addin-mock": "^3.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "ultracite": "^7.2.5",
    "vitest": "^3.2.0"
  }
}
